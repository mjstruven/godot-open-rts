[gd_scene load_steps=2 format=3 uid="uid://combatmenu00001"]

[ext_resource type="Script" path="res://source/match/hud/unit-menus/CombatMenu.gd" id="1_cmbmnu"]

[node name="CombatMenu" type="GridContainer"]
mouse_filter = 2
columns = 4
script = ExtResource("1_cmbmnu")

[node name="AttackMoveButton" type="Button" parent="."]
layout_mode = 2
focus_mode = 0
text = "AM"
tooltip_text = "Attack Move [Q]"

[node name="PatrolButton" type="Button" parent="."]
layout_mode = 2
focus_mode = 0
text = "PA"
tooltip_text = "Patrol [W]"

[node name="StandGroundButton" type="Button" parent="."]
layout_mode = 2
focus_mode = 0
text = "SG"
tooltip_text = "Stand Ground [E]"

[node name="CaptureButton" type="Button" parent="."]
layout_mode = 2
focus_mode = 0
disabled = true
text = "CA"
tooltip_text = "Capture Structure [R] - Coming soon"

[node name="SuppressButton" type="Button" parent="."]
layout_mode = 2
focus_mode = 0
text = "SP"
tooltip_text = "Suppress [S]\nRoot archers. +2 range, +50% fire rate.\nCost: 1 wood per archer. Toggle: press again to cancel.\nCooldown: 5s after deactivation."

[node name="RallyButton" type="Button" parent="."]
layout_mode = 2
focus_mode = 0
text = "RL"
tooltip_text = "Rally [F]\nBoost nearby allied units: +20% speed, +20% attack rate.\nRadius: 8 tiles. Duration: 15s. Cooldown: 45s."

[node name="Pad6" type="Control" parent="."]
custom_minimum_size = Vector2(48, 48)
layout_mode = 2
mouse_filter = 2

[node name="Pad7" type="Control" parent="."]
custom_minimum_size = Vector2(48, 48)
layout_mode = 2
mouse_filter = 2

[node name="DismissButton" type="Button" parent="."]
layout_mode = 2
focus_mode = 0
text = "DIS"
tooltip_text = "Dismiss unit(s) — 15s countdown, then civilians spawn"

[node name="Pad9" type="Control" parent="."]
custom_minimum_size = Vector2(48, 48)
layout_mode = 2
mouse_filter = 2

[node name="Pad10" type="Control" parent="."]
custom_minimum_size = Vector2(48, 48)
layout_mode = 2
mouse_filter = 2

[node name="Pad11" type="Control" parent="."]
custom_minimum_size = Vector2(48, 48)
layout_mode = 2
mouse_filter = 2

[node name="CancelButton" type="Button" parent="."]
layout_mode = 2
focus_mode = 0
