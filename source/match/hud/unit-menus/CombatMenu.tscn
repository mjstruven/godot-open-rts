[connection signal="pressed" from="AttackMoveButton" to="." method="_on_attack_move_pressed"]
[connection signal="pressed" from="PatrolButton" to="." method="_on_patrol_pressed"]
[connection signal="pressed" from="StandGroundButton" to="." method="_on_stand_ground_pressed"]
[connection signal="pressed" from="CaptureButton" to="." method="_on_capture_pressed"]
[connection signal="pressed" from="RallyButton" to="." method="_handle_rally_click"]
[connection signal="pressed" from="DismissButton" to="." method="_on_dismiss_pressed"]
[connection signal="pressed" from="CancelButton" to="." method="_on_cancel_button_pressed"]
